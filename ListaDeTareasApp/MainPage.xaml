<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ListaDeTareasApp.MainPage"
             Title="Mis tareas">

    <Grid Padding="20" RowDefinitions="Auto,*" RowSpacing="16">
        <Button
            Text="Agregar tarea"
            Clicked="OnAgregarTareaClicked"
            HorizontalOptions="Fill" />

        <CollectionView
            x:Name="TareasCollectionView"
            Grid.Row="1"
            SelectionMode="Single"
            SelectionChanged="OnTareaSeleccionada">
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="20" Spacing="8" VerticalOptions="Center">
                    <Label
                        Text="No hay tareas registradas."
                        FontSize="18"
                        HorizontalTextAlignment="Center" />
                    <Label
                        Text="Presiona Agregar tarea para crear la primera."
                        TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray200}}"
                        HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,10" Padding="14">
                        <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                            <Label
                                Text="{Binding Nombre}"
                                FontAttributes="Bold"
                                FontSize="18" />
                            <Label
                                Grid.Row="1"
                                Text="{Binding Descripcion}"
                                LineBreakMode="TailTruncation"
                                MaxLines="2"
                                TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray200}}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
